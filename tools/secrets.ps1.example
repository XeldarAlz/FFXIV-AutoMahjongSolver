# Template for local credentials used by tools/*.
# Copy to .local/secrets.ps1 (.local/ is gitignored), fill in real values,
# then dot-source it from the repo root before running any tool:
#
#   . .\.local\secrets.ps1
#   powershell -File tools\fetch-worker-logs.ps1
#   node tools\b2-pull.mjs memdumps <install-id> 2026-05-10
#
# Rotate the credentials kept in .local/secrets.ps1 whenever you suspect
# leakage (chat logs, screen shares, accidental commits before .gitignore):
#   - Cloudflare token: https://dash.cloudflare.com/profile/api-tokens
#   - B2 keys:          https://secure.backblaze.com/app_keys.htm

$env:CLOUDFLARE_API_TOKEN  = "cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
$env:CLOUDFLARE_ACCOUNT_ID = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
$env:B2_KEY_ID             = "xxxxxxxxxxxxxxxxxxxxxxxxx"
$env:B2_APPLICATION_KEY    = "Kxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
