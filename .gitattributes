# Default to auto-detection of text vs binary, with the working tree using
# the platform's native line endings (CRLF on Windows, LF on Unix). Files
# below override this where a fixed line ending matters.

* text=auto

# .NET source / project files: keep CRLF in the working tree on every
# platform. Mixed line endings inside csproj files break some IDE tooling.
*.cs       text eol=crlf
*.cshtml   text eol=crlf
*.csproj   text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf
*.sln      text eol=crlf
*.config   text eol=crlf
*.ruleset  text eol=crlf

# Tooling / data files: LF is canonical and most parsers expect it.
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.sh       text eol=lf
*.py       text eol=lf
*.toml     text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore     text eol=lf

# PowerShell scripts: CRLF (Windows-native).
*.ps1      text eol=crlf

# Binary files: never touch line endings; never diff as text.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.zip      binary
*.dll      binary
*.exe      binary
*.pdb      binary
*.bin      binary

# Generated lock files: text but excluded from human-friendly diffs.
packages.lock.json text eol=lf -diff
